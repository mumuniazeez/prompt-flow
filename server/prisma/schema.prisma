// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  firstName String
  lastName  String

  email String @unique

  profileImage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]

  @@map("users")
}

model Project {
  id String @id @default(uuid())

  name        String
  description String

  userId    String
  user      User       @relation(fields: [userId], references: [id])
  endpoints Endpoint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
}

model Endpoint {
  id String @id @default(uuid())

  name        String
  description String
  method      EndpointMethod
  route       String

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  responseSchema   ResponseSchema @relation(fields: [responseSchemaId], references: [id])
  responseSchemaId String         @unique

  @@map("endpoints")
}

model Field {
  id String @id @default(uuid())

  name        String
  description String?
  datatype    FieldDataType

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  responseSchema   ResponseSchema @relation(fields: [responseSchemaId], references: [id])
  responseSchemaId String

  @@map("fields")
}

model ResponseSchema {
  id String @id @default(uuid())

  systemPrompt String?
  instruction  String?

  endpoint Endpoint?
  field    Field[]

  @@map("responseSchemas")
}

enum EndpointMethod {
  GET
  POST
  PATCH
  PUT
  DELETE
}

enum FieldDataType {
  string
  number
  boolean
  object
  array
}
